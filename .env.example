# Copy to .env and fill in values. Used by docker-compose, ingestion, and the app.
# Required for ingestion: OPENROUTER_API_KEY. Qdrant must be running (e.g. docker compose up -d qdrant).

# ========== Required for ingestion (python -m ingestion.run) ==========
# Get your key at: https://openrouter.ai/keys (used for embeddings: nvidia/llama-nemotron-embed-vl-1b-v2:free)
OPENROUTER_API_KEY=

# ========== Optional: Qdrant (ingestion and RAG; defaults below) ==========
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION=aml_rag

# ========== Docker / other services ==========
# Cohere (reranker service; optional — RAG works without it)
COHERE_API_KEY=

# Neo4j (used by neo4j container and Graphiti MCP)
NEO4J_PASSWORD=yourpassword

# Graphiti MCP (knowledge graph) — needs an LLM for entity extraction
OPENAI_API_KEY=

# Optional: Azure OpenAI for RAG (used by app)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

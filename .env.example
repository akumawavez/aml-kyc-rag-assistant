# Copy to .env and fill in values. Used by docker-compose and the app.

# --- OpenRouter (free and paid LLM models: https://openrouter.ai/models?max_price=0) ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: base URL (defaults to https://openrouter.ai/api/v1 if app supports it)
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# --- Cohere (for reranker service) ---
COHERE_API_KEY=

# --- Neo4j (used by neo4j container and Graphiti MCP) ---
NEO4J_PASSWORD=yourpassword

# --- Graphiti MCP (knowledge graph over Neo4j) — needs an LLM for entity extraction ---
# Use OpenAI, or point to OpenRouter-compatible endpoint if your app supports it
OPENAI_API_KEY=

# --- Qdrant (for ingestion and RAG; defaults: localhost:6333) ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION=aml_rag

# --- Optional: Azure OpenAI for RAG (used by app) ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

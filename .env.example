# Change the name of this file to .env after updating it!

############
# [required]
# OpenRouter — used for embeddings (nvidia/llama-nemotron-embed-vl-1b-v2:free) and LLM (e.g. gemma-2-9b-it:free).
# Get your key at: https://openrouter.ai/keys
############

OPENROUTER_API_KEY=

############
# [optional] Qdrant — ingestion and RAG (defaults: localhost:6333, collection aml_rag)
# Only needed if not using defaults.
############

# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION=aml_rag

############
# [optional] Cohere — reranker service (Docker). RAG works without it; reranker returns top N in order when set.
############

COHERE_API_KEY=

############
# [optional] n8n (Docker) — if you enable user management / encryption, set these.
# Generate with: openssl rand -hex 32  (Linux/Mac or Git Bash on Windows)
# Or: python -c "import secrets; print(secrets.token_hex(32))"
############

# N8N_ENCRYPTION_KEY=
# N8N_USER_MANAGEMENT_JWT_SECRET=

############
# [optional] Neo4j (Docker) — used by neo4j container and Graphiti MCP. Not required for Phase 1 RAG-only scope.
# Format: username/password (e.g. neo4j/yourpassword). Avoid @ in password (can break URL parsing).
############

NEO4J_PASSWORD=yourpassword

############
# [optional] Graphiti MCP / OpenAI — only if using Knowledge Graph (out of current phase scope).
# Or use OpenRouter for LLM; set OPENROUTER_API_KEY above.
############

# OPENAI_API_KEY=

############
# [optional] Langfuse — Phase 2 observability (tracing, token/cost). Use cloud or self-hosted.
# Cloud: set LANGFUSE_PUBLIC_KEY and LANGFUSE_SECRET_KEY from Langfuse project settings.
############

# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

############
# [optional] Azure OpenAI — if app uses Azure instead of OpenRouter.
############

# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
